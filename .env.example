# Copy to `.env` for local development. Never commit `.env` (see `.gitignore`).
# The binary does not auto-load this file — see README "Run a release binary" for `source .env` / Compose options.
# Optional launch flags: `-admin-token` / `-listen` (see README); env and Compose remain the recommended default for servers.
# Variables are read with plain `os.Getenv` (no automatic `.env` loading until optional Step 1.5).

# SQLite database file path (file only; not :memory:). Parent directories are created on startup.
DNSFLEET_DB_PATH=./data/dnsfleet.db

# HTTP listen address (used when the server is wired in Step 1.5).
DNSFLEET_HTTP_ADDR=:8080

# --- 业务 API /api/v1：详见 api/DNSFLEET_HTTP_API.md；行为裁决见本机 docs/详细开发计划.md ---
# Admin 密钥。除非 DNSFLEET_ADMIN_INSECURE_DISABLE=1，否则 token 为空（仅空白）时进程启动失败。
DNSFLEET_ADMIN_TOKEN=replace_me

# 仅本地开发：精确为 1 时跳过 Admin 且不要求 token。生产禁止使用。
# DNSFLEET_ADMIN_INSECURE_DISABLE=1

# 可选：对 AdGH 的并发上限（默认 8）；漂移与 POST /sync 共用同一 semaphore。
# DNSFLEET_SYNC_MAX_CONCURRENT=8

# 可选：整次 POST /api/v1/sync 总超时（默认 5m，Go duration 语法）。
# DNSFLEET_SYNC_TOTAL_TIMEOUT=5m

# 可选：漂移检测间隔（默认 5m）；启动后会先立即跑一轮再进入 ticker。
# DNSFLEET_DRIFT_INTERVAL=5m

# --- Step 4：聚合查询日志 WebSocket + querylog 轮询（实现到位后生效；裁决见 api/DNSFLEET_HTTP_API.md）---
# 对 AdGH 的 querylog 轮询并发上限（与 DNSFLEET_SYNC_MAX_CONCURRENT 独立）。
# DNSFLEET_QUERYLOG_MAX_CONCURRENT=8
# 每节点轮询间隔（Go duration，默认 2s）。
# DNSFLEET_QUERYLOG_POLL_INTERVAL=2s
# 单次 GET /control/querylog 的 limit（默认 100）。
# DNSFLEET_QUERYLOG_PAGE_LIMIT=100
# 下发给浏览器的单条 WebSocket 文本帧最大字节数（默认 65536）。
# DNSFLEET_WS_MAX_FRAME_BYTES=65536

# 数据库路径请使用 DNSFLEET_DB_PATH（不再使用 DNSFLEET_DATA_DIR）
