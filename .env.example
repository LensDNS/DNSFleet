# Copy to `.env` for local development. Never commit `.env` (see `.gitignore`).
# The binary does not auto-load this file — see README "Run a release binary" for `source .env` / Compose options.
# Optional launch flags: `-admin-token` / `-listen` (see README); env and Compose remain the recommended default for servers.
# Variables are read with plain `os.Getenv` (the process does not read `.env` automatically).

# SQLite database file path (file only; not :memory:). Parent directories are created on startup.
DNSFLEET_DB_PATH=./data/dnsfleet.db

# HTTP listen address (Echo).
DNSFLEET_HTTP_ADDR=:8080

# --- Admin / `/api/v1` (see `api/DNSFLEET_HTTP_API.md`) ---
# Shared secret for REST and WebSocket. Unless DNSFLEET_ADMIN_INSECURE_DISABLE=1, startup fails if the token is empty (whitespace-only counts as empty).
DNSFLEET_ADMIN_TOKEN=replace_me

# Local development only: when exactly `1`, skips Admin middleware and allows an empty token. Do not use in production or on exposed networks.
# DNSFLEET_ADMIN_INSECURE_DISABLE=1

# Optional: max concurrent AdGuard Home HTTP calls for drift, POST /sync, per-node querylog/probe (default 8). Shared semaphore.
# DNSFLEET_SYNC_MAX_CONCURRENT=8

# Optional: total timeout for POST /api/v1/sync (default 5m; Go duration syntax).
# DNSFLEET_SYNC_TOTAL_TIMEOUT=5m

# Optional: drift check interval (default 5m); one drift run runs immediately on startup, then on the ticker.
# DNSFLEET_DRIFT_INTERVAL=5m

# --- Query log hub (see `api/DNSFLEET_HTTP_API.md`; independent of DNSFLEET_SYNC_MAX_CONCURRENT) ---
# Max concurrent GET /control/querylog calls from the hub.
# DNSFLEET_QUERYLOG_MAX_CONCURRENT=8
# Per-node poll interval (Go duration; default 2s).
# DNSFLEET_QUERYLOG_POLL_INTERVAL=2s
# Single-page limit for GET /control/querylog (default 100).
# DNSFLEET_QUERYLOG_PAGE_LIMIT=100
# Max outbound WebSocket text frame size to browsers (default 65536).
# DNSFLEET_WS_MAX_FRAME_BYTES=65536

# Use DNSFLEET_DB_PATH for the database file (DNSFLEET_DATA_DIR is not used).
