# Copy to .env.local for local dev (never commit .env.local).

# Control plane origin for Next rewrites (read by next.config at dev/build/start; no NEXT_PUBLIC_).
# Must be reachable from the Next Node process (not the browser). Trim trailing slash in config.
# Align host:port with DNSFLEET_HTTP_ADDR on the Go side (e.g. http://127.0.0.1:8080 if Echo listens on :8080).
DNSFLEET_BACKEND_URL=http://127.0.0.1:8080

# Optional: browser REST base. Unset or empty string = use relative "/api/v1" (recommended with rewrites).
# Do NOT set to the backend origin when using rewrites — that bypasses the proxy and causes CORS failures.
# NEXT_PUBLIC_API_BASE=

# DEV ONLY: same value as control plane DNSFLEET_ADMIN_TOKEN. Exposed in client bundle — not for production as sole auth.
# NEXT_PUBLIC_DNSFLEET_ADMIN_TOKEN=replace_me
